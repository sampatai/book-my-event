@using Microsoft.AspNetCore.Identity
@using Domain.Users.Root

@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<ul class="flex items-center gap-3 text-sm">
@if (SignInManager.IsSignedIn(User))
{
    <li>
        <a id="manage" class="text-slate-600 hover:text-slate-900" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">Hello @UserManager.GetUserName(User)!</a>
    </li>
    <li>
        <form id="logoutForm" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button id="logout" type="submit" class="rounded-md border border-slate-300 px-3 py-1.5 text-slate-700 hover:bg-slate-100">Logout</button>
        </form>
    </li>
}
else
{
    <li>
        <a class="rounded-md bg-slate-900 px-3 py-1.5 text-white hover:bg-slate-800" id="login" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>
