@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="mx-auto flex min-h-[80vh] w-full max-w-md items-center justify-center px-4">
    <section class="w-full rounded-xl border border-slate-200 bg-white p-8 shadow-sm">
        <div class="mb-6 space-y-1">
            <h1 class="text-3xl font-semibold tracking-tight text-slate-900">Login to your account</h1>
            <p class="text-sm text-slate-500">Enter your email below to login to your account</p>
        </div>

        <form id="account" method="post" class="space-y-4">
            <div asp-validation-summary="ModelOnly" class="rounded-md border border-red-200 bg-red-50 p-3 text-sm text-red-700" role="alert"></div>

            <div class="space-y-2">
                <div class="flex items-center gap-1">
                    <label asp-for="Input.Email" class="text-sm font-medium text-slate-700">Email</label>
                    <span class="text-red-500">*</span>
                </div>
                <input asp-for="Input.Email" class="h-10 w-full rounded-md border border-slate-300 px-3 text-sm outline-none ring-offset-2 transition focus:border-slate-400 focus:ring-2 focus:ring-slate-200" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="text-xs text-red-600"></span>
            </div>

            <div class="space-y-2">
                <div class="flex items-center justify-between">
                    <label asp-for="Input.Password" class="text-sm font-medium text-slate-700">Password</label>
                    <a href="#" class="text-sm text-slate-600 hover:text-slate-900">Forgot your password?</a>
                </div>
                <input asp-for="Input.Password" class="h-10 w-full rounded-md border border-slate-300 px-3 text-sm outline-none ring-offset-2 transition focus:border-slate-400 focus:ring-2 focus:ring-slate-200" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="text-xs text-red-600"></span>
            </div>

            <label class="flex items-center gap-2 text-sm text-slate-600" asp-for="Input.RememberMe">
                <input class="h-4 w-4 rounded border-slate-300" asp-for="Input.RememberMe" />
                @Html.DisplayNameFor(m => m.Input.RememberMe)
            </label>

            <button id="login-submit" type="submit" class="inline-flex h-10 w-full items-center justify-center rounded-md bg-slate-900 px-4 text-sm font-medium text-white transition hover:bg-slate-800">
                Log in
            </button>
        </form>

        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            <div class="mt-4 space-y-3">
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="space-y-2">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" class="inline-flex h-10 w-full items-center justify-center rounded-md border border-slate-300 px-3 text-sm hover:bg-slate-50" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">Login with @provider.DisplayName</button>
                    }
                </form>
            </div>
        }

        <p class="mt-5 text-center text-sm text-slate-500">
            Don't have an account?
            <a href="#" class="font-medium text-slate-800 underline underline-offset-4">Sign up</a>
        </p>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
